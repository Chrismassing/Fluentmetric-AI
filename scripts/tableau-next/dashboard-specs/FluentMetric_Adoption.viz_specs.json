{
  "workspace_label": "FluentMetric AI",
  "pattern": "f_layout",
  "pattern_args": {
    "title_text": "FluentMetric AI — Adoption Health"
  },
  "metrics": [
    "Active_Users_mtc",
    "Total_Tokens_mtc",
    "Avg_Tokens_Per_Request_mtc"
  ],
  "filters": [
    { "fieldName": "Department" },
    { "fieldName": "Title" },
    { "fieldName": "Feature" },
    { "fieldName": "Model" },
    { "fieldName": "Timestamp1" },
    { "fieldName": "Username" }
  ],
  "visualizations": [
    {
      "name": "Active_Users_by_Department",
      "label": "Active Users by Department",
      "template": "revenue_by_category",
      "fields": {
        "category": "Department",
        "amount": "Distinct_Active_Users_clc"
      },
      "color_dim": "Title"
    },
    {
      "name": "Active_Users_Trend_by_Department",
      "label": "Active Users Trend by Department",
      "template": "multi_series_line",
      "fields": {
        "date": "Timestamp1",
        "measure": "Distinct_Active_Users_clc",
        "color_dim": "Department"
      }
    },
    {
      "name": "Active_Users_by_Title_and_Department",
      "label": "Active Users by Title and Department",
      "template": "stacked_bar_by_dimension",
      "fields": {
        "category": "Title",
        "stack_dim": "Department",
        "amount": "Distinct_Active_Users_clc"
      }
    },
    {
      "name": "Top_Features_by_Active_Users",
      "label": "Top Features by Active Users",
      "template": "revenue_by_category",
      "fields": {
        "category": "Feature",
        "amount": "Distinct_Active_Users_clc"
      },
      "color_dim": "Department",
      "sort": { "field": "Distinct_Active_Users_clc", "direction": "DESC" },
      "limit": 10
    },
    {
      "name": "Active_Users_Heatmap_Department_x_Title",
      "label": "Active Users by Department and Title",
      "template": "heatmap_grid",
      "fields": {
        "row_dim": "Department",
        "col_dim": "Title",
        "measure": "Distinct_Active_Users_clc"
      }
    }
  ]
}

<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>FluentMetric Tableau Agent Chat</masterLabel>
    <description>Mount point for the FluentMetric Tableau Analyst Agentforce agent. In v1 this renders a launch button that opens the Einstein Copilot panel; once Salesforce ships an embeddable agent component for App Pages, swap the body for it.</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage,lightning__RecordPage">
            <property name="agentApiName" type="String" label="Agent API Name" default="FluentMetric_Tableau_Analyst"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>

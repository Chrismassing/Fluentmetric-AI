<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>FluentMetric AI for Tableau Next User</label>
    <description>Grants access to the FluentMetric AI for Tableau Next app, KPI tile, launcher, and Tableau Analyst agent. Recipients still need a Tableau Next license, Data Cloud read perms, and access to the FluentMetric_AI semantic model.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <license>Salesforce</license>
    <classAccesses>
        <apexClass>FmTableauNextController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>GetUsageOverviewAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>GetUsageByUserAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>GetUsageByPromptAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AiInsightsService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AiInsightsDAO</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>UserResolverService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DateRangeFilter</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>UsageOverviewDTO</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>UserUsageDTO</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PromptUsageDTO</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <tabSettings>
        <tab>FluentMetric_AI_Tableau</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <applicationVisibilities>
        <application>FluentMetric_AI_Tableau</application>
        <visible>true</visible>
    </applicationVisibilities>
</PermissionSet>
